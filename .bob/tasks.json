{
    "version": "2.0.0",
    "tasks": [
        // --- LARAVEL ADMINPORTAL TASKS ---
        {
            "label": "Laravel: Serve AdminPortal",
            "type": "shell",
            "command": "php artisan serve --host=0.0.0.0",
            "options": {
                "cwd": "${workspaceFolder}/Tradexpro-AdminPortal"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "servers"
            },
            "runOptions": {
                "instanceLimit": 1
            }
        },
        {
            "label": "Laravel: Run Migrations",
            "type": "shell",
            "command": "php artisan migrate",
            "options": {
                "cwd": "${workspaceFolder}/Tradexpro-AdminPortal"
            },
            "problemMatcher": []
        },
        {
            "label": "Laravel: Run Migrations with Seed",
            "type": "shell",
            "command": "php artisan migrate --seed",
            "options": {
                "cwd": "${workspaceFolder}/Tradexpro-AdminPortal"
            },
            "problemMatcher": []
        },
        {
            "label": "Laravel: Fresh Migration",
            "type": "shell",
            "command": "php artisan migrate:fresh --seed",
            "options": {
                "cwd": "${workspaceFolder}/Tradexpro-AdminPortal"
            },
            "problemMatcher": []
        },
        {
            "label": "Laravel: Clear Cache",
            "type": "shell",
            "command": "php artisan cache:clear && php artisan config:clear && php artisan route:clear && php artisan view:clear",
            "options": {
                "cwd": "${workspaceFolder}/Tradexpro-AdminPortal"
            },
            "problemMatcher": []
        },
        {
            "label": "Laravel: Run Tests",
            "type": "shell",
            "command": "php artisan test",
            "options": {
                "cwd": "${workspaceFolder}/Tradexpro-AdminPortal"
            },
            "problemMatcher": []
        },
        {
            "label": "Laravel: Run PHPStan",
            "type": "shell",
            "command": "./vendor/bin/phpstan analyse",
            "options": {
                "cwd": "${workspaceFolder}/Tradexpro-AdminPortal"
            },
            "problemMatcher": []
        },
        {
            "label": "Laravel: Queue Work",
            "type": "shell",
            "command": "php artisan queue:work",
            "options": {
                "cwd": "${workspaceFolder}/Tradexpro-AdminPortal"
            },
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "Composer: Install (AdminPortal)",
            "type": "shell",
            "command": "composer install",
            "options": {
                "cwd": "${workspaceFolder}/Tradexpro-AdminPortal"
            },
            "problemMatcher": []
        },
        {
            "label": "Composer: Update (AdminPortal)",
            "type": "shell",
            "command": "composer update",
            "options": {
                "cwd": "${workspaceFolder}/Tradexpro-AdminPortal"
            },
            "problemMatcher": []
        },

        // --- NEXT.JS USERPORTAL TASKS ---
        {
            "label": "Next.js: Dev Server (UserPortal)",
            "type": "npm",
            "script": "dev",
            "path": "Tradexpro-UserPortal/",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "servers"
            },
            "runOptions": {
                "instanceLimit": 1
            }
        },
        {
            "label": "Next.js: Build (UserPortal)",
            "type": "npm",
            "script": "build",
            "path": "Tradexpro-UserPortal/",
            "problemMatcher": []
        },
        {
            "label": "Next.js: Start Production (UserPortal)",
            "type": "npm",
            "script": "start",
            "path": "Tradexpro-UserPortal/",
            "problemMatcher": []
        },
        {
            "label": "Next.js: Lint (UserPortal)",
            "type": "npm",
            "script": "lint",
            "path": "Tradexpro-UserPortal/",
            "problemMatcher": ["$eslint-stylish"]
        },
        {
            "label": "NPM: Install (UserPortal)",
            "type": "shell",
            "command": "npm install --legacy-peer-deps",
            "options": {
                "cwd": "${workspaceFolder}/Tradexpro-UserPortal"
            },
            "problemMatcher": []
        },
        {
            "label": "NPM: Clean Install (UserPortal)",
            "type": "shell",
            "command": "rm -rf node_modules package-lock.json && npm install --legacy-peer-deps",
            "options": {
                "cwd": "${workspaceFolder}/Tradexpro-UserPortal"
            },
            "problemMatcher": []
        },

        // --- NODE WALLET TASKS ---
        {
            "label": "Node: Start Wallet Service",
            "type": "npm",
            "script": "start",
            "path": "Tradexpro-NodeWallet/",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "servers"
            },
            "runOptions": {
                "instanceLimit": 1
            }
        },
        {
            "label": "Node: Dev Wallet Service (with nodemon)",
            "type": "shell",
            "command": "nodemon index.js",
            "options": {
                "cwd": "${workspaceFolder}/Tradexpro-NodeWallet"
            },
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "NPM: Install (NodeWallet)",
            "type": "npm",
            "script": "install",
            "path": "Tradexpro-NodeWallet/",
            "problemMatcher": []
        },

        // --- DATABASE TASKS ---
        {
            "label": "MySQL: Start Service",
            "type": "shell",
            "command": "sudo systemctl start mysql",
            "problemMatcher": []
        },
        {
            "label": "MySQL: Stop Service",
            "type": "shell",
            "command": "sudo systemctl stop mysql",
            "problemMatcher": []
        },
        {
            "label": "MySQL: Restart Service",
            "type": "shell",
            "command": "sudo systemctl restart mysql",
            "problemMatcher": []
        },
        {
            "label": "MySQL: Status",
            "type": "shell",
            "command": "sudo systemctl status mysql",
            "problemMatcher": []
        },

        // --- PM2 TASKS ---
        {
            "label": "PM2: Start All Services",
            "type": "shell",
            "command": "pm2 start 'php artisan serve --host=0.0.0.0' --name admin-portal --cwd /var/app/Tradexpro-AdminPortal && pm2 start npm --name user-portal --cwd /var/app/Tradexpro-UserPortal -- run dev && pm2 start npm --name wallet-service --cwd /var/app/Tradexpro-NodeWallet -- start",
            "problemMatcher": []
        },
        {
            "label": "PM2: Stop All Services",
            "type": "shell",
            "command": "pm2 stop all",
            "problemMatcher": []
        },
        {
            "label": "PM2: Restart All Services",
            "type": "shell",
            "command": "pm2 restart all",
            "problemMatcher": []
        },
        {
            "label": "PM2: Status",
            "type": "shell",
            "command": "pm2 status",
            "problemMatcher": []
        },
        {
            "label": "PM2: Logs",
            "type": "shell",
            "command": "pm2 logs",
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "PM2: Delete All",
            "type": "shell",
            "command": "pm2 delete all",
            "problemMatcher": []
        },

        // --- GIT TASKS ---
        {
            "label": "Git: Pull All Modules",
            "type": "shell",
            "command": "cd Tradexpro-AdminPortal && git pull && cd ../Tradexpro-UserPortal && git pull && cd ../Tradexpro-NodeWallet && git pull",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Git: Status All Modules",
            "type": "shell",
            "command": "echo '=== AdminPortal ===' && cd Tradexpro-AdminPortal && git status && echo '\n=== UserPortal ===' && cd ../Tradexpro-UserPortal && git status && echo '\n=== NodeWallet ===' && cd ../Tradexpro-NodeWallet && git status",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },

        // --- DOCKER TASKS ---
        {
            "label": "Docker: Build All",
            "type": "shell",
            "command": "docker-compose build",
            "problemMatcher": []
        },
        {
            "label": "Docker: Up",
            "type": "shell",
            "command": "docker-compose up -d",
            "problemMatcher": []
        },
        {
            "label": "Docker: Down",
            "type": "shell",
            "command": "docker-compose down",
            "problemMatcher": []
        },
        {
            "label": "Docker: Logs",
            "type": "shell",
            "command": "docker-compose logs -f",
            "problemMatcher": [],
            "isBackground": true
        },

        // --- UTILITY TASKS ---
        {
            "label": "Check Ports",
            "type": "shell",
            "command": "echo 'Port 8000:' && sudo lsof -i :8000 && echo '\nPort 3000:' && sudo lsof -i :3000 && echo '\nPort 8934:' && sudo lsof -i :8934",
            "problemMatcher": []
        },
        {
            "label": "Kill Port 8000",
            "type": "shell",
            "command": "sudo kill -9 $(sudo lsof -t -i:8000)",
            "problemMatcher": []
        },
        {
            "label": "Kill Port 3000",
            "type": "shell",
            "command": "sudo kill -9 $(sudo lsof -t -i:3000)",
            "problemMatcher": []
        },
        {
            "label": "Kill Port 8934",
            "type": "shell",
            "command": "sudo kill -9 $(sudo lsof -t -i:8934)",
            "problemMatcher": []
        },

        // --- COMPOUND TASKS ---
        {
            "label": "Start All Development Servers",
            "dependsOn": [
                "Laravel: Serve AdminPortal",
                "Next.js: Dev Server (UserPortal)",
                "Node: Start Wallet Service"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": []
        }
    ]
}

